{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "if": {
          "tool_input": {
            "file_path": ".*\\.py$"
          }
        },
        "hooks": [
          {
            "type": "command",
            "command": "uvx --from torchshapeflow[mcp] tsf _hook_post_edit"
          }
        ]
      }
    ]
  }
}
