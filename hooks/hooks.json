{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "if": {
          "tool_input": {
            "file_path": ".*\\.py$"
          }
        },
        "hooks": [
          {
            "type": "command",
            "command": "python3 ${CLAUDE_PLUGIN_ROOT}/hooks/post_edit.py"
          }
        ]
      }
    ]
  }
}
